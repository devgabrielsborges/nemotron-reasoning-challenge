KAGGLE_COMPETITION_NAME=nvidia-nemotron-model-reasoning-challenge
DATASET_SOURCE=kaggle
# HF_DATASET=author/name
DATA_RAW_DIR=data/raw/
TARGET_COLUMN="answer"
ID_COLUMN="id"
PROMPT_COLUMN="prompt"
SVD_COMPONENTS=256
METRIC="accuracy"
TASK_TYPE="classification"
MLFLOW_TRACKING_URI=http://localhost:5000
LOG_ALL_METRICS=False

# Nemotron LoRA training
# Optional local model path. If unset, kagglehub downloads from NEMOTRON_KAGGLE_MODEL_HANDLE.
# NEMOTRON_MODEL_PATH=/path/to/local/nemotron-model
NEMOTRON_KAGGLE_MODEL_HANDLE=metric/nemotron-3-nano-30b-a3b-bf16/transformers/default
NEMOTRON_TRAIN_CSV=data/raw/train.csv
NEMOTRON_OUTPUT_DIR=artifacts/adapter
NEMOTRON_SUBMISSION_PATH=artifacts/submission.zip

# Keep rank <= 32 for competition compatibility.
NEMOTRON_LORA_RANK=8
NEMOTRON_LORA_ALPHA=16
NEMOTRON_LORA_DROPOUT=0.05
NEMOTRON_LORA_TARGET_MODULES=out_proj
NEMOTRON_MAX_SEQ_LEN=512
NEMOTRON_NUM_EPOCHS=1
NEMOTRON_GRAD_ACCUM=8
NEMOTRON_LR=2e-4
NEMOTRON_WEIGHT_DECAY=0.01
NEMOTRON_BATCH_SIZE=1
NEMOTRON_WARMUP_RATIO=0.03
NEMOTRON_LOGGING_STEPS=10
NEMOTRON_SAVE_STEPS=200
NEMOTRON_OPTIMIZER=adafactor
NEMOTRON_RANDOM_SEED=42
# NEMOTRON_SUBSAMPLE_SIZE=600

# QLoRA / quantization (recommended on 24GB GPUs)
# Keep false when NEMOTRON_USE_CPU_OFFLOAD=true (4-bit + CPU/disk dispatch is unsupported)
NEMOTRON_USE_4BIT=false
NEMOTRON_BNB_COMPUTE_DTYPE=bfloat16
NEMOTRON_BNB_QUANT_TYPE=nf4
NEMOTRON_BNB_USE_DOUBLE_QUANT=true

# VRAM controls (recommended for mixed-GPU systems)
NEMOTRON_CUDA_VISIBLE_DEVICES=0,1
NEMOTRON_USE_CPU_OFFLOAD=true
NEMOTRON_GPU_MAX_MEMORY_GIB=10
NEMOTRON_CPU_MAX_MEMORY_GIB=120
NEMOTRON_OFFLOAD_DIR=artifacts/offload

KAGGLE_TOKEN=

# MinIO/S3 credentials for artifact storage
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000